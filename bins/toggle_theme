#!/bin/bash

# Define paths
DOTFILES="$HOME/dotfiles"
HYPR_DIR="$DOTFILES/configs/hyprland/.config/hypr"
FOOT_DIR="$DOTFILES/configs/foot/.config/foot"
QUICKSHELL_DIR="$DOTFILES/configs/quickshell/.config/quickshell"

detect_target_from_symlink() {
    # Detect current theme by checking where theme.conf points to
    if [ -L "$HYPR_DIR/theme.conf" ]; then
        CURRENT=$(readlink "$HYPR_DIR/theme.conf")
        if [[ "$CURRENT" == *"mocha.conf"* ]]; then
            echo "latte"
        else
            echo "mocha"
        fi
    else
        # Default to mocha if symlink doesn't exist
        echo "mocha"
    fi
}

detect_target_from_portal() {
    local COLOR_SCHEME

    COLOR_SCHEME=$(gdbus call \
        --session \
        --dest org.freedesktop.portal.Desktop \
        --object-path /org/freedesktop/portal/desktop \
        --method org.freedesktop.portal.Settings.Read \
        org.freedesktop.appearance \
        color-scheme 2>/dev/null) || return 1

    case "$COLOR_SCHEME" in
        *"uint32 1"*) echo "latte" ;; # Portal currently prefers dark
        *"uint32 2"*) echo "mocha" ;; # Portal currently prefers light
        *) return 1 ;; # No preference or unsupported response
    esac
}

sync_portal_preference() {
    if ! command -v gsettings >/dev/null 2>&1; then
        return
    fi

    if [[ "$(gsettings writable org.gnome.desktop.interface color-scheme 2>/dev/null)" != "true" ]]; then
        return
    fi

    if [[ "$TARGET" == "mocha" ]]; then
        gsettings set org.gnome.desktop.interface color-scheme prefer-dark
    else
        gsettings set org.gnome.desktop.interface color-scheme prefer-light
    fi
}

TARGET=$(detect_target_from_portal || detect_target_from_symlink)

echo "Switching theme to: $TARGET"

if [[ "$TARGET" == "mocha" ]]; then
    # Swap symlinks in dotfiles repo
    ln -sf mocha.conf "$HYPR_DIR/theme.conf"
    ln -sf mocha_hyprpaper.conf "$HYPR_DIR/hyprpaper.conf"
    ln -sf mocha.ini "$FOOT_DIR/theme.ini"
    ln -sf Mocha.qml "$QUICKSHELL_DIR/Theme.qml"
else
    # Swap symlinks in dotfiles repo
    ln -sf latte.conf "$HYPR_DIR/theme.conf"
    ln -sf latte_hyprpaper.conf "$HYPR_DIR/hyprpaper.conf"
    ln -sf latte.ini "$FOOT_DIR/theme.ini"
    ln -sf Latte.qml "$QUICKSHELL_DIR/Theme.qml"
fi

sync_portal_preference

# Reload applications
hyprctl reload

# Reload Hyprpaper
if pgrep -x hyprpaper > /dev/null; then
    killall hyprpaper
    sleep 0.2
    hyprpaper > /dev/null 2>&1 &
fi

# Reload Foot
if pgrep -x foot > /dev/null; then
    killall -SIGUSR1 foot
fi

# Restart quickshell (as requested, it's better to restart it)
if pgrep quickshell > /dev/null; then
    killall quickshell
    sleep 0.2
    quickshell > /dev/null 2>&1 &
fi
